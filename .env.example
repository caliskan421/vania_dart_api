# ===========================================
# Railway / Production Environment Variables
# ===========================================
# Bu dosyadaki değişkenleri Railway Dashboard > Variables bölümüne ekleyin.
# APP_KEY: base64 formatında rastgele key (örn: openssl rand -base64 32)

# --- Uygulama ---
APP_NAME=first_vania_project
APP_ENV=production
APP_KEY=YENİ_KEY_ÜRETİN
APP_HOST=0.0.0.0
APP_DEBUG=false
APP_URL=https://your-app.railway.app
APP_WEBSOCKET=false
APP_SECURE=false
APP_SHARED=true

# --- Veritabanı (Railway MySQL veya harici) ---
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_SECURE=true
DB_POOL=true
DB_POOL_SIZE=2

# --- Cache ---
CACHE_DRIVER=file
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Session ---
SESSION_LIFETIME=86400

# --- Storage ---
STORAGE=local

# --- Mail (opsiyonel) ---
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=465
MAIL_ENCRYPTION=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=first_vania_project
